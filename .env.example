# Forest Fire Detection - Environment Variables
# Copy this to .env and fill in your API keys

# NASA FIRMS API
FIRMS_MAP_KEY=your_firms_api_key_here
FIRMS_WMS_URL=https://firms.modaps.eosdis.nasa.gov/wms/
ENABLE_FIRMS_WMS=true
FIRMS_DAYS_DEFAULT=1

# OpenWeather API
OPENWEATHER_KEY=your_openweather_api_key_here

# Sentinel Hub (Optional)
SENTINELHUB_CLIENT_ID=your_sentinel_client_id_here
SENTINELHUB_CLIENT_SECRET=your_sentinel_client_secret_here
SENTINEL_WMS_URL=https://tiles.maps.eox.at/wms

# Azure Configuration (Production)
# Set these in Azure App Service Configuration -> Application Settings
# PORT=8000
